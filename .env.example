# ── Backend (Express) ─────────────────────────────────────────────────────────
PORT=3001

# Supabase server-side (service role — bypasses RLS)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# OpenAI
OPENAI_API_KEY=sk-...

# CORS — comma-separated origins allowed to call the Express API
ALLOWED_ORIGINS=http://localhost:3000

# Kumii host origin — used for postMessage security & Express CORS
KUMII_HOST_ORIGIN=http://localhost:3000
KUMII_TRUSTED_ORIGINS=http://localhost:3000

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ── Frontend (Vite + React) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

VITE_KUMII_HOST_ORIGIN=http://localhost:3000
VITE_KUMII_TRUSTED_ORIGINS=http://localhost:3000
